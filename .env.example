# Copy this file to `.env.local` for local-only secrets.
# `.env.local` is ignored by git and must never be pushed to GitHub.

OPENAI_API_KEY=
OPENAI_BASE_URL=
PRACTICE_PROVIDER_NAME=qwen
PRACTICE_MODEL=qwen3.5-flash
PRACTICE_TIMEOUT_SEC=60
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_OCR_MODEL=gemini-2.5-flash
GEMINI_MAX_RETRIES=3
DOUBAO_API_KEY=
DOUBAO_ENDPOINT_ID=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_TIMEOUT_SEC=60
OCR_PAGE_BATCH_SIZE=4
OCR_RENDER_DPI=160
ALLOW_PLACEHOLDER_FALLBACK=false
GITHUB_REMOTE_URL=
MAX_UPLOAD_SIZE_MB=200
